<Window x:Class="EvidenceStudentu.PridatStudenta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EvidenceStudentu"
        mc:Ignorable="d"
        Title="PridatStudenta" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Jméno"/>
            <TextBox x:Name="txtJmeno" Width="751"/>

            <TextBlock Text="Příjmení"/>
            <TextBox x:Name="txtPrijmeni"/>

            <TextBlock Text="Věk"/>
            <TextBox x:Name="txtVek"/>

            <Button Content="Uložit"
            Click="BtnUlozit_Click"
            Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
